#Requires AutoHotkey v2.0

/**
 * 配置模块
 * 包含所有可配置的参数和初始化逻辑
 */

; ==========================================
; ⚙️ 游戏窗口配置
; ==========================================

/**
 * 游戏窗口标题
 * 如果不确定，可以留空 ""，脚本会默认操作当前激活的窗口
 */
GameWindowTitle := "Idle Champions"

; ==========================================
; 🎨 颜色检测配置
; ==========================================

/**
 * 需要点击的颜色数组
 * 格式：["0xRRGGBB", ...]
 */
TargetColors := ["0x5CCB2F", "0x5CABF7"]  ; 绿色，蓝色

/**
 * 颜色误差容差 (0-255)
 * 因为游戏可能有光影效果，颜色不会完全一样，建议设为 10-30
 */
ColorVariance := 20

; ==========================================
; 🔘 按钮坐标配置
; ==========================================

/**
 * 按钮起始 X 坐标
 */
ButtonStartX := 230

/**
 * 按钮宽度（像素）
 */
ButtonWidth := 173

/**
 * 按钮 Y 坐标
 */
ButtonY := 1384

/**
 * 按钮数量
 */
ButtonCount := 13

/**
 * 按钮坐标数组（由上述参数计算生成）
 * 格式：[[x1, y1], [x2, y2], ...]
 */
ButtonCoords := []
Loop ButtonCount {
    x := ButtonStartX + (A_Index - 1) * ButtonWidth
    ButtonCoords.Push([x, ButtonY])
}

; ==========================================
; ⏱️ 扫描频率配置
; ==========================================

/**
 * 检测频率（毫秒）
 * 每多少毫秒扫描一次屏幕，建议 200-500
 */
ScanInterval := 3000

; ==========================================
; 🖼️ 选择按钮图片配置
; ==========================================

/**
 * "选择"按钮图片路径
 * 若出现绿色"选择"按钮，优先点击
 */
SelectButtonImage := "select-btn.png"

/**
 * 图像搜索容差
 * 可根据需要调大
 */
SelectImageVariance := 200

; ==========================================
; 👾 敌人区域扫描配置
; ==========================================

/**
 * 扫描区域左上角 X 坐标
 */
EnemyAreaStartX := 1027

/**
 * 扫描区域左上角 Y 坐标
 */
EnemyAreaStartY := 461

/**
 * 扫描区域右下角 X 坐标
 */
EnemyAreaEndX := 2462

/**
 * 扫描区域右下角 Y 坐标
 */
EnemyAreaEndY := 1000

/**
 * 每行扫描间距（像素）
 * 默认 50
 */
EnemyAreaScanLineSpacing := 50

/**
 * 蛇形扫描每步移动的像素距离
 * 默认 50
 */
EnemyAreaScanStep := 50

/**
 * 鼠标移动速度 (0-100)
 * 0=瞬间移动，数值越大越慢
 * 默认 3
 */
EnemyAreaMouseMoveSpeed := 50

; ==========================================
; 🔴 调试配置
; ==========================================

/**
 * 是否启用调试标记
 * true=绘制红色圆圈标记坐标位置
 */
EnableDebugMarkers := true

/**
 * 按钮坐标标记半径（像素）
 */
DebugMarkerRadius := 15

/**
 * 扫描区域顶点标记半径（像素）
 */
DebugVertexMarkerRadius := 20
